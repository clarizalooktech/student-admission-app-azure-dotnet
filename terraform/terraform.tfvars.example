# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — never commit it.

subscription_id       = "your-azure-subscription-id"
resource_group_name   = "student-admission-app-azure-dotnet-rg"
location              = "australiaeast"
app_name              = "student-admission-app-azure-dotnet"
environment           = "dev"
acr_name              = "acradmissiondemo"       # must be globally unique
openai_endpoint       = "https://YOUR-RESOURCE.openai.azure.com/"
openai_api_key        = "your-openai-api-key"
openai_model          = "gpt-4o-mini"
create_infrastructure = true                      # set to false after first deploy
